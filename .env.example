# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# お墓じまいナビ 環境変数テンプレート
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# このファイルは .env のテンプレートです。
# コピーして .env を作成し、値を設定してください。
#   cp .env.example .env

# ── Database (Supabase) ──────────────────
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-1-ap-northeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-1-ap-northeast-2.pooler.supabase.com:5432/postgres"

# ── Supabase Auth ────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# ── Site ─────────────────────────────────
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ── Email (Resend) ───────────────────────
RESEND_API_KEY=""

# ── Analytics (GA4) ──────────────────────
NEXT_PUBLIC_GA_ID=""

# ── Microsoft Clarity ────────────────────
NEXT_PUBLIC_CLARITY_ID=""

# ── Stripe 決済 ───────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_ID_BASIC=""
STRIPE_PRICE_ID_STANDARD=""
STRIPE_PRICE_ID_PREMIUM=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# ── AI機能フィーチャーフラグ ─────────────────
# Doc-19 §2.8: 公開RAGチャットの有効化フラグ
# ⚠️ 内部AI監査バッチが最低30日間安定稼働し、重大違反ゼロが確認されるまで
#    この値を 'true' にしてはならない（デフォルト: 未設定 = 非表示）
NEXT_PUBLIC_ENABLE_RAG_CHAT=""

# ── Cron認証 ─────────────────────────────────
# Vercel Cron / 手動実行のための認証シークレット
# /api/check-links および /api/audit エンドポイントで使用
CRON_SECRET=""

# ── 内部AI監査バッチ (Vercel Cron経由) ──────
# staging / production で run_ai_audit.ts 相当のバッチを動かすためのAPIキー
OPENAI_API_KEY=""

# ── Upstash Redis (レート制限) ─────────────
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
